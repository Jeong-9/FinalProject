<Window x:Class="LabSafetyManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="실험실 안전 관리 시스템" Height="800" Width="1280"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen" Background="#15161A">

    <Window.Resources>
        <!-- ===== 비상 화면 애니메이션 ===== -->
        <Storyboard x:Key="FlashStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetName="EmergencyBgBrush"
                            Storyboard.TargetProperty="Color"
                            From="#AAD50000" To="#AAFFC400" Duration="0:0:0.45"/>
        </Storyboard>
        <Storyboard x:Key="BeaconStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Beacon"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.2" Duration="0:0:0.45"/>
            <DoubleAnimation Storyboard.TargetName="BeaconScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.4" Duration="0:0:0.45"/>
            <DoubleAnimation Storyboard.TargetName="BeaconScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.4" Duration="0:0:0.45"/>
        </Storyboard>

        <!-- ===== 공통 스타일 ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E2026"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AA0A6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9AA0A6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatusValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EAED"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="#E8EAED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#363941"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2127"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#7A1C1C"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainLayer">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== Header ===== -->
            <Border Grid.Row="0" Background="#1A1C21">
                <Grid Margin="20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="🛡" FontSize="22" Foreground="#7AB8FF"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="실험실 안전 관리 시스템" Foreground="#E8EAED"
                                   FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" x:Name="ClockText"
                               Foreground="#9AA0A6" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <Border Grid.Column="2" x:Name="OverallBadge"
                            Background="#1F4D2E" CornerRadius="14" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="OverallDot" Width="10" Height="10"
                                     Fill="#2ECC71" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OverallText" Text="정상"
                                       Foreground="#E8EAED" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ===== Row 1: 카메라(좌) + 상태 패널(우) ===== -->
            <Grid Grid.Row="1" Margin="12,12,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- 카메라 카드 -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 카메라 선택 바 -->
                        <Grid Grid.Row="0" Margin="14,12,14,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="카메라" Foreground="#9AA0A6" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="CameraCombo" Grid.Column="1"
                                      SelectionChanged="CameraCombo_SelectionChanged"
                                      Padding="8,4" MinHeight="30"/>
                            <Button Grid.Column="2" Content="🔄 새로고침"
                                    Click="RefreshCamerasButton_Click"
                                    Style="{StaticResource ActionButton}"
                                    Padding="10,4" Margin="8,0,0,0"
                                    ToolTip="USB 카메라를 새로 꽂은 뒤 누르세요"/>
                        </Grid>

                        <!-- 영상 영역 -->
                        <Grid Grid.Row="1" Margin="14,0,14,14">
                            <Border Background="Black" CornerRadius="8">
                                <Image x:Name="VideoImage" Stretch="Uniform"/>
                            </Border>
                            <TextBlock x:Name="CameraOverlay" Text="카메라 검색 중..."
                                       Foreground="#777" FontSize="16" TextAlignment="Center"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Margin="12" Background="#80000000" CornerRadius="4" Padding="8,4">
                                <TextBlock x:Name="CameraBadge" Text="● LIVE"
                                           Foreground="#FF6B6B" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 상태 패널 -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="시스템 상태" Style="{StaticResource PanelTitle}"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="카메라 연결" Style="{StaticResource StatusLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Ellipse x:Name="CamDot" Width="10" Height="10" Fill="#888"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="CamStatusText" Text="대기"
                                           Style="{StaticResource StatusValue}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="사람 감지" Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Column="1" x:Name="PersonStatusText"
                                       Text="—" Style="{StaticResource StatusValue}"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="쓰러짐 감지" Style="{StaticResource StatusLabel}"/>
                            <TextBlock Grid.Column="1" x:Name="FallStatusText"
                                       Text="—" Style="{StaticResource StatusValue}"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="위험 단계" Style="{StaticResource StatusLabel}"/>
                            <Border Grid.Column="1" x:Name="LevelBadge"
                                    Background="#1F4D2E" CornerRadius="10" Padding="10,3">
                                <TextBlock x:Name="LevelText" Text="정상"
                                           Foreground="#E8EAED" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <Rectangle Height="1" Fill="#2A2D34" Margin="0,12"/>

                        <TextBlock Text="최근 감지" Style="{StaticResource PanelTitle}"/>
                        <TextBlock x:Name="LastDetectionText" Text="기록 없음"
                                   Foreground="#E8EAED" FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== Row 2: 이벤트 로그(좌) + 조치 버튼(우) ===== -->
            <Grid Grid.Row="2" Margin="12,6,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="이벤트 로그" Style="{StaticResource PanelTitle}" Margin="0"/>
                            <TextBlock Grid.Column="1" x:Name="LogCountText" Text="0건"
                                       Foreground="#9AA0A6" FontSize="12"/>
                        </Grid>
                        <ListView x:Name="LogListView" Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0,2"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TimeText}" Foreground="#9AA0A6"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Column="1" Width="8" Height="8"
                                                 Fill="{Binding LevelBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Message}"
                                                   Foreground="#E8EAED" FontSize="13"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="조치" Style="{StaticResource PanelTitle}"/>
                        <Button Content="🧪  테스트 감지"
                                Style="{StaticResource ActionButton}" Click="TestButton_Click"/>
                        <Button Content="🚨  비상 호출"
                                Style="{StaticResource DangerButton}" Click="CallEmergencyButton_Click"/>
                        <Button Content="✓  경고 해제"
                                Style="{StaticResource ActionButton}" Click="ClearButton_Click"/>
                        <Button Content="🔄  카메라 재시작"
                                Style="{StaticResource ActionButton}" Click="RestartCameraButton_Click"/>
                        <Button Content="💾  로그 저장"
                                Style="{StaticResource ActionButton}" Click="SaveLogButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== 비상 오버레이 (반투명 - 뒤에 카메라 화면 비침) ===== -->
        <Grid x:Name="EmergencyOverlay" Visibility="Collapsed">
            <Grid.Background>
                <!-- ★ AA = 67% 불투명 → 뒤 화면이 비쳐 보임 -->
                <SolidColorBrush x:Name="EmergencyBgBrush" Color="#AAD50000"/>
            </Grid.Background>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse x:Name="Beacon" Width="120" Height="120" Fill="#FFFFFF"
                         RenderTransformOrigin="0.5,0.5" Margin="0,0,0,30">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="BeaconScale" ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="White" BlurRadius="60" ShadowDepth="0"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock Text="⚠ 비상 상황" FontSize="84" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="쓰러짐이 감지되었습니다" FontSize="40"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock x:Name="EmergencyTime" FontSize="22"
                           Foreground="#FFEFEF" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <Button x:Name="AckButton" Content="확인 / 해제" FontSize="26"
                        Padding="40,14" Margin="0,50,0,0"
                        HorizontalAlignment="Center" Click="AckButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
